#:kivy 2.3


<PostPageScreen>:
    id: posts
    PostPageScreenCanvas:
        FloatLayout:
            MDTopAppBar:
                title: "My Hobbies"
                left_action_items: [["home", lambda x: app.go_home()]]
                pos_hint: {"top": 1}

            MDGridLayout:
                cols: 2  # 🔹 2 columns
                rows: 3  # 🔹 3 rows
                spacing: "10dp"
                padding: "10dp"
                size_hint: 1, 0.8
                pos_hint: {"center_x": 0.5, "center_y": 0.45}

                # 🔹 Hobby 1
                BoxLayout:
                    orientation: "vertical"
                    spacing: "4dp"
                    Image:
                        source: "Cat_November_2010-1a.jpg"
                        size_hint_y: None
                        height: self.width
                        allow_stretch: True
                        keep_ratio: True
                    MDLabel:
                        text: "Cat"
                        halign: "center"
                        size_hint_y: None
                        height: "20dp"

                # 🔹 Hobby 2
                BoxLayout:
                    orientation: "vertical"
                    spacing: "4dp"
                    Image:
                        source: "Cat_November_2010-1a.jpg"
                        size_hint_y: None
                        height: self.width
                        allow_stretch: True
                        keep_ratio: True
                    MDLabel:
                        text: "Cat"
                        halign: "center"
                        size_hint_y: None
                        height: "20dp"

                # 🔹 Hobby 3
                BoxLayout:
                    orientation: "vertical"
                    spacing: "4dp"
                    Image:
                        source: "Cat_November_2010-1a.jpg"
                        size_hint_y: None
                        height: self.width
                        allow_stretch: True
                        keep_ratio: True

                    MDLabel:
                        text: "Mandalorian Suit"
                        halign: "center"
                        size_hint_y: None
                        height: "20dp"


                # 🔹 Hobby 4
                BoxLayout:
                    orientation: "vertical"
                    spacing: "8dp"
                    Image:
                        source: "fennac_shand_sq.jpg"
                        size_hint_y: None
                        height: self.width
                        allow_stretch: True
                        keep_ratio: True

                    MDLabel:
                        text: "Fennac Shand Suit"
                        halign: "center"
                        size_hint_y: None
                        height: "20dp"


                # 🔹 Hobby 5
                BoxLayout:
                    orientation: "vertical"
                    spacing: "4dp"
                    Image:
                        source: "taskmaster.jpg"
                        size_hint_y: None
                        height: self.width
                        allow_stretch: True
                        keep_ratio: True

                    MDLabel:
                        text: "Taskmaster Suit"
                        halign: "center"
                        size_hint_y: None
                        height: "20dp"


                # 🔹 Hobby 6
                BoxLayout:
                    orientation: "vertical"
                    spacing: "4dp"
                    Image:
                        source: "captain_rex_sq.jpg"
                        size_hint_y: None
                        height: self.width
                        allow_stretch: True
                        keep_ratio: True

                    MDLabel:
                        text: "Captain Rex Suit"
                        halign: "center"
                        size_hint_y: None
                        height: "20dp"


<FavoritesScreen>:
    id: favorites
    FavoritesScreenCanvas:
        FloatLayout:
            MDTopAppBar:
                title: "My Favorites"
                left_action_items: [["home", lambda x: app.go_home()]]
                pos_hint: {"top": 1}
